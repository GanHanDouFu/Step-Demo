{
  "version": 2,
  "builds": [
    { "src": "server.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/server.js" },
    { "src": "/gallery.html", "dest": "/public/gallery.html" },
    { "src": "/(.*\\.(html|css|js|png|jpg|svg|ico|json))", "dest": "/public/$1" },
    { "src": "/(.*)", "dest": "/server.js" }
  ]
}
